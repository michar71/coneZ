# conez-master configuration (optional).
#
# Copy to conez-master.ini to override the hard-coded defaults in conez-master.py.
# All keys are optional; anything omitted keeps its built-in default (shown here).
# Precedence:  built-in defaults  <  this file  <  env vars (DEADTIME,
# DIST_TEST_DROP_DATA).  Re-read at runtime with:  conez-masterctl reload
#
# File path override:  CONEZ_MASTER_CONFIG=/path/to/file python3 conez-master.py

[lora]
mode       = lora          ; "lora" or "fsk" (selects the [fsk] section below)
network    = 0             ; ConeZ network id 0-255; stamped in every packet header — both modes
frequency  = 431250000     ; Hz  (431.250 MHz, 70 cm amateur band) — used by both modes
bandwidth  = 500000        ; Hz  (500 kHz)        — LoRa only
sf         = 7             ; spreading factor 7..12 — LoRa only
cr         = 5             ; coding rate denominator -> 4/5 — LoRa only
preamble   = 8             ; preamble symbols — LoRa only
tx_power   = 0             ; dBm, -9..+22 (via the per-power PA table) — both modes
sync_word  = 0xDEAD        ; 0x.. hex or decimal — LoRa only
# LDRO is DERIVED from sf/bandwidth (must match the cone's auto-LDRO) — not a key.

[fsk]
# Used only when [lora] mode = fsk. Defaults match the cone's RadioLib beginFSK +
# the scanlist FSK entry (F <freq> 4800 5000 9700 0x2D). Set [lora] frequency too.
bitrate       = 4800       ; bps
freqdev       = 9600       ; Hz  (9.6 kHz dev, h=4.0; secondary offset-margin factor -- rxbw is the lossless lever)
rxbw          = 29300      ; Hz  (DSB RX BW -- THE lever: 29.3 kHz ~0% loss, 19.5 kHz ~4.6% even at 4800 Hz dev; SX126x register)
sync          = 0xDEAD     ; FSK sync word (hex, 1+ bytes); matches the LoRa sync word
preamble_bits = 32         ; master TX preamble bits (>= the cone's preamble detector)
whitening     = 1          ; 1 = on (seed 0x01FF, matches the cone); 0 = NRZ
# CRC is fixed to 2-byte CCITT-inverted (init 0x1D0F / poly 0x1021) to match RadioLib.

[master]
beacon_period = 10         ; seconds between beacons
deadtime      = 0.1        ; seconds between downstream transmissions
callsign      = N1AF       ; FCC station ID carried in the v1 beacon

[dist]
dir              = dist          ; distributable payload directory
manifest_dir     = dist-state    ; where manifest_<N>.txt + serial.txt live
manifest_interval = 60           ; seconds between manifest (re)broadcasts -- the carousel
                                 ;   entry point (a cone can't act on data/fw chunks without it).
                                 ;   A freshly-built manifest is broadcast promptly regardless.
file_per_fw      = 1             ; WEIGHTED carousel (spec 13.7): data-FILE chunks sent per
                                 ;   FIRMWARE chunk -- a FLOAT. >1 prioritizes files (4 = 4 file:1 fw,
                                 ;   small files stay responsive); 1 = even; <1 prioritizes firmware
                                 ;   (0.25 = 1 file:4 fw, push an image faster). (<=0 -> 1.0)
test_drop_data   = 0             ; bench FEC test: drop last K data chunks/block (0=off)

[control]
socket = /tmp/conez-master.sock   ; Unix control socket (conez-masterctl)
