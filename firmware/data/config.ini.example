; ConeZ configuration file
; Copy to /config.ini and edit as needed.
; Only include settings you want to override — missing keys use compiled defaults.

[wifi]
enabled=on
ssid=RN-ConeZ
password=conezconez

[gps]
origin_lat=40.762173
origin_lon=-119.193672

[lora]
enabled=on                 ; master on/off for the LoRa subsystem (default on)
rx_only=off                ; listen-only: inhibit ALL transmit (default off)
ota_downgrade=off          ; dist firmware OTA: accept older/= versions (default off = newer only)
ssid=ConeZ
frequency=431.250
bandwidth=500.0
sf=9
cr=6
preamble=8
tx_power=10
sync_word=0x12
callsign=
; mode=lora                ; "lora" (default) or "fsk" -- selects the [fsk] section

; [fsk] -- FSK PHY params (used only when [lora] mode=fsk). Matches the master's INI.
; [fsk]
; bitrate=4.8              ; kbps (0.6-300)
; freqdev=10.0             ; kHz (0.6-200); h~4. secondary offset-margin factor -- rxbw below is the lossless lever
; rxbw=29.3                ; kHz (discrete set: 4.8-467); THE lever -- must comfortably pass the signal+skirts (29.3 ~0% loss; 19.5 lost ~4.6% even at 4800 Hz dev)
; shaping=0                ; 0=none, 1=BT0.3, 2=BT0.5, 3=BT0.7, 4=BT1.0
; whitening=off            ; data whitening (improves bit-clock recovery on long packets)
; sync=12AD                ; hex string, 2-16 hex chars (1-8 bytes)
; crc=2                    ; 0=off, 1=1-byte, 2=2-byte

[system]
device_name=
; startup_script=          ; empty = auto-detect (.bas, .c, .wasm)
timezone=-8
auto_dst=on
cone_id=0
cone_group=0
; ntp_server=192.168.1.100   ; local NTP server (default: pool.ntp.org)
; ntp_interval=3600          ; seconds between NTP re-syncs (default: 3600)
; cpu_max=240                ; Max CPU frequency MHz (80/160/240)
; cpu_min=80                 ; Min CPU frequency MHz. Same as max = fixed, lower = DFS.

[mqtt]
; broker=sewerpipe.local
; port=1883
enabled=on

[led]
count1=50
count2=50
count3=50
count4=50
;color1=0xFF0000
;color2=0x00FF00
;color3=0x0000FF
;color4=0x000000

[debug]
system=on
basic=on
wasm=on
commands=on
gps=off
gps_raw=off
lora=off
lora_raw=off
lora_dist=on
wifi=off
sensors=off
mqtt=on
other=off
